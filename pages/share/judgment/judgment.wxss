.container {
  padding: 20rpx;
  background-color: #f7f7f7;
  min-height: 100vh;
}

/* Judgment Card Style */
.judgment-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.judgment-card .header {
  margin-bottom: 8rpx;
}

.judgment-card .title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  line-height: 1.4;
}

.judgment-card .stats {
  display: flex;
  align-items: center;
}

.judgment-card .subtitle {
  font-size: 28rpx;
  font-weight: 600;
  color: #555;
  background: #f0f2f5;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.judgment-card .meta {
  font-size: 24rpx;
  color: #999;
  display: flex;
  gap: 16rpx;
  margin-top: 8rpx;
}

/* Themes */
.judgment-card.red .title { color: #d9534f; }
.judgment-card.red .subtitle { background: #ffebeb; color: #d9534f; }

.judgment-card.green .title { color: #2e8b57; }
.judgment-card.green .subtitle { background: #e8f5e9; color: #2e8b57; }

.judgment-card.yellow .title { color: #f0ad4e; }
.judgment-card.yellow .subtitle { background: #fcf8e3; color: #8a6d3b; }

/* Evidence List */
.evidence-list {
  margin-bottom: 30rpx;
}

.evidence-item {
  background: #fff;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: #eee;
}

.user-name {
  font-size: 26rpx;
  color: #666;
  flex: 1;
}

.rating-tag {
  font-size: 20rpx;
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
}

.rating-tag.rec { background: #ffebeb; color: #d9534f; }
.rating-tag.avoid { background: #e8f5e9; color: #2e8b57; }

.content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  display: block;
  margin-bottom: 12rpx;
}

.item-footer .time {
  font-size: 22rpx;
  color: #bbb;
}

/* Map */
.mini-map {
  width: 100%;
  height: 300rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.action-area {
  padding-bottom: 60rpx;
}

.btn-main {
  background: #333;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: 600;
}
