.container {
  background-color: #F7F7F7;
  min-height: 100vh;
  padding-bottom: 200rpx;
}

.form-section {
  background-color: #fff;
  padding: 32rpx;
  margin-bottom: 24rpx;
}

.input-group {
  margin-bottom: 32rpx;
}

.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.input {
  background-color: #F5F6F7;
  height: 88rpx;
  padding: 0 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
}

.textarea {
  background-color: #F5F6F7;
  width: 100%;
  height: 160rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  box-sizing: border-box;
}

.char-count {
  font-size: 24rpx;
  color: #999;
  text-align: right;
  display: block;
  margin-top: 8rpx;
}



.location-section {
  background-color: #fff;
  padding: 32rpx;
}

.section-header {
  margin-bottom: 24rpx;
}

.helper-text {
  font-size: 24rpx;
  color: #999;
  margin-left: 12rpx;
}

.location-list {
  max-height: 800rpx;
}

.location-item {
  display: flex;
  align-items: flex-start;
  padding: 32rpx 0;
  border-bottom: 1rpx solid #F0F0F0;
  position: relative;
}

.location-item:last-child {
  border-bottom: none;
}

.loc-checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #DDD;
  border-radius: 50%;
  margin-right: 24rpx;
  margin-top: 4rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  flex-shrink: 0;
  transition: all 0.2s;
}

.location-item.selected .loc-checkbox {
  background-color: #07C160;
  border-color: #07C160;
  transform: scale(1.1);
}

.loc-content {
  flex: 1;
  display: flex;
  align-items: flex-start;
}

.loc-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 20rpx;
}

.loc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.loc-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
}

.loc-address {
  font-size: 26rpx;
  color: #999;
  line-height: 1.4;
}

.loc-comment {
  font-size: 28rpx;
  color: #666;
  line-height: 1.5;
  margin-top: 4rpx;
  padding: 16rpx;
  background-color: #F7F8FA;
  border-radius: 8rpx;
}

.loc-detail-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background-color: #F5F6F7;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 16rpx;
  flex-shrink: 0;
  margin-top: 4rpx;
  transition: all 0.2s;
}

.loc-detail-btn:active {
  background-color: #E5E6E7;
  transform: scale(0.95);
}

.detail-icon {
  font-size: 32rpx;
  color: #666;
  font-weight: 600;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background-color: #fff;
  box-shadow: 0 -4rpx 12rpx rgba(0,0,0,0.05);
}

.submit-btn {
  background-color: #DDD;
  color: #fff;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
}

.submit-btn.active {
  background-color: #07C160;
}

.empty-locs {
  padding: 80rpx 40rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
  line-height: 1.6;
}
