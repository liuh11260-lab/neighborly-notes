.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F7F7F7 0%, #EDEDED 100%);
  display: flex;
  flex-direction: column;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 加载状态 */
.loading-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-icon {
  font-size: 48rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.1); opacity: 0.7; }
}

.loading-text {
  margin-top: 20rpx;
  color: #666;
  font-size: 28rpx;
}

/* 主内容 */
.main-content {
  flex: 1;
  padding: 30rpx;
}

/* 顶部标题区 */
.panel-header {
  margin-bottom: 40rpx;
  padding: 0 10rpx;
}

.panel-title {
  font-size: 42rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #333 0%, #666 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 12rpx;
  display: block;
  line-height: 1.3;
}

.panel-subtitle {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  display: block;
}

/* 地点卡片 */
.location-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.location-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.location-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.location-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.location-address {
  font-size: 24rpx;
  color: #999;
  margin-top: 6rpx;
}

.location-action {
  margin-left: 20rpx;
}

.change-btn {
  font-size: 26rpx;
  color: #07C160;
}

/* 判断选择 */
.judgment-section {
  margin-top: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.optional {
  font-weight: 400;
  color: #999;
  font-size: 24rpx;
}

.judgment-options {
  display: flex;
  gap: 20rpx;
}

.judgment-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #eee;
  transition: all 0.2s ease;
}

.judgment-btn.active {
  border-color: #07C160;
  background: rgba(7, 193, 96, 0.05);
}

.judgment-btn.recommend.active {
  border-color: #FF4D4F;
  background: rgba(255, 77, 79, 0.05);
}

.judgment-btn.avoid.active {
  border-color: #52C41A;
  background: rgba(82, 196, 26, 0.05);
}

.judgment-btn.neutral.active {
  border-color: #8C8C8C;
  background: rgba(140, 140, 140, 0.05);
}

.judgment-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.judgment-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
}

.judgment-sub {
  font-size: 24rpx;
  color: #666;
  margin-top: 8rpx;
  text-align: center;
}

.judgment-hint {
  font-size: 20rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: center;
  line-height: 1.4;
}

.footer-hint {
  margin-top: 40rpx;
  font-size: 22rpx;
  color: #999;
  text-align: center;
}

/* 评语输入 */
.comment-section {
  margin-top: 40rpx;
  position: relative;
}

.comment-input {
  width: 100%;
  height: 180rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 2rpx solid #eee;
}

.comment-input:focus {
  border-color: #07C160;
}

.char-count {
  position: absolute;
  bottom: 16rpx;
  right: 24rpx;
  font-size: 22rpx;
  color: #999;
}

/* 底部按钮 */
.footer {
  padding: 30rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.submit-btn.active {
  background: linear-gradient(135deg, #07C160 0%, #06AD56 100%);
  color: #fff;
}

.submit-btn.disabled {
  background: #E0E0E0;
  color: #999;
}

/* 空间尺度选择 */
.spatial-section {
  margin-top: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.level-switcher {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.level-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 4rpx solid transparent;
  transition: all 0.2s;
}

.level-item.active {
  border-color: #07C160;
  background: rgba(7, 193, 96, 0.05);
}

.level-icon-svg {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.level-text {
  font-size: 22rpx;
  color: #666;
}
