.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f8f9fa;
  position: relative;
}

/* View Header */
.view-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 40rpx 40rpx;
  background: #fff;
  z-index: 10;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.header-content {
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  color: #222;
  margin-bottom: 8rpx;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
}

.toggle-btn {
  padding: 12rpx 28rpx;
  background: #07c160;
  color: #fff;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.2);
}

/* Dual View Logic */
.map-view, .list-view {
  flex: 1;
  position: absolute;
  top: 160rpx;
  left: 0;
  right: 0;
  bottom: 120rpx;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.3s ease;
  background: #f8f9fa;
}

.map-view.active, .list-view.active {
  opacity: 1;
  pointer-events: auto;
  z-index: 5;
}

/* Map Mode */
.nearby-map {
  width: 100%;
  height: 100%;
}

/* List Mode */
.list-container {
  padding: 30rpx;
}

.imprint-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.04);
}

.imprint-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.user-block {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #eee;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.imprint-meta {
  font-size: 22rpx;
  color: #bbb;
}

.judgment-badge {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  font-weight: bold;
}

.judgment-badge.recommend {
  background: rgba(7, 193, 96, 0.1);
  color: #07c160;
}

.judgment-badge.avoid {
  background: rgba(255, 77, 79, 0.1);
  color: #ff4d4f;
}

.judgment-badge.neutral {
  background: rgba(0, 0, 0, 0.05);
  color: #888;
}

.imprint-body {
  margin-bottom: 24rpx;
}

.location-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #07c160;
  margin-bottom: 12rpx;
  display: block;
}

.comment-text {
  font-size: 28rpx;
  color: #444;
  line-height: 1.6;
}

.imprint-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #f2f2f2;
}

.link-label {
  font-size: 22rpx;
  color: #999;
}

.arrow {
  color: #ddd;
}

/* Empty State */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 100rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #bbb;
}

/* Global Footer */
.page-footer {
  height: 120rpx;
  background: #fff;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #eee;
  z-index: 10;
}

.page-footer text {
  font-size: 24rpx;
  color: #bbb;
}

.footer-hint {
  font-weight: bold;
  margin-top: 4rpx;
}
