page {
  background: #F7F7F7;
}

.container {
  padding: 40rpx;
  min-height: 100vh;
}

/* Identity Header */
.identity-header {
  margin-bottom: 60rpx;
  padding: 0 10rpx;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 900;
  color: #000;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: #666;
}

/* Notes List */
.notes-list {
  display: flex;
  flex-direction: column;
  padding-bottom: 120rpx;
}

.note-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
  transition: all 0.2s ease;
}

.note-card:active {
  transform: scale(0.98);
  background: #FAFAFA;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.note-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
  flex: 1;
  margin-right: 20rpx;
  line-height: 1.3;
}

.note-time {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
  margin-top: 6rpx;
}

.card-meta {
  margin-bottom: 24rpx;
}

.note-address {
  font-size: 24rpx;
  color: #999;
}

/* Judgment Section */
.judgment-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1rpx solid #F5F5F5;
  padding-top: 24rpx;
}

.card-judgment {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
}

.judgment-icon {
  margin-right: 12rpx;
  font-size: 30rpx;
}

.card-judgment.positive { color: #000; } /* Black for Suitable (Identity) */
.card-judgment.positive .judgment-icon { color: #07C160; }

.card-judgment.negative { color: #999; }
.card-judgment.neutral { color: #666; }

.modify-btn {
  font-size: 24rpx;
  color: #999;
  padding: 8rpx 20rpx;
  background: #F9F9F9;
  border-radius: 30rpx;
  font-weight: 500;
}

/* States */
.loading-state, .end-state {
  text-align: center;
  padding: 40rpx;
  color: #CCC;
  font-size: 24rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 120rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #CCC;
  margin-bottom: 16rpx;
}

.empty-sub {
  font-size: 24rpx;
  color: #DDD;
}
