.container {
  background-color: #fff;
  min-height: 100vh;
  padding: 40rpx;
  box-sizing: border-box;
}

.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 40rpx;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.update-date,
.effective-date {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.content {
  padding-bottom: 60rpx;
}

.section {
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.section-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
  white-space: pre-wrap;
}
