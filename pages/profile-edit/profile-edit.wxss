.page {
  min-height: 100vh;
  background: #F7F7F7;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部头像区 ===== */
.hero {
  padding: 120rpx 0 80rpx;
  display: flex;
  justify-content: center;
}

.avatar-button {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  border-radius: 110rpx;
  padding: 0;
  background: none;
}

.avatar-button::after {
  border: none;
}

.avatar-image {
  width: 100%;
  height: 100%;
  border-radius: 110rpx;
  background: #EEE;
}

.avatar-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 72rpx;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom-left-radius: 110rpx;
  border-bottom-right-radius: 110rpx;
}

.mask-text {
  font-size: 24rpx;
  color: #fff;
}

/* ===== 表单区 ===== */
.form {
  padding: 0 48rpx;
}

.field {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
}

.field-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
  display: block;
}

.field-input {
  font-size: 32rpx;
  color: #222;
  height: 44rpx;
}

/* ===== 底部操作区 ===== */
.footer {
  margin-top: auto;
  padding: 40rpx 48rpx 64rpx;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  background: #E0E0E0;
  color: #fff;
}

.save-btn.active {
  background: #07C160;
}