.admin-page {
  min-height: 100vh;
  background-color: #F7F8FA;
  padding: 32rpx;
  color: #333;
}

.admin-header {
  margin-bottom: 48rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 700;
  display: block;
}

.header-status {
  font-size: 24rpx;
  color: #999;
}

.data-card {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #EEE;
}

.user-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #F0F0F0;
  margin-right: 20rpx;
}

.user-main {
  flex: 1;
}

.user-nickname {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
}

.user-id {
  font-size: 18rpx;
  color: #BBB;
  font-family: monospace;
}

.user-badge {
  font-size: 18rpx;
  background-color: #333;
  color: #fff;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.user-meta {
  font-size: 20rpx;
  color: #999;
  border-top: 1rpx solid #F0F0F0;
  padding-top: 16rpx;
}

.search-section {
  margin-bottom: 24rpx;
}

.search-bar {
  background-color: #fff;
  height: 72rpx;
  border-radius: 36rpx;
  padding: 0 32rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #EEE;
}

.search-input {
  flex: 1;
  margin-left: 12rpx;
  font-size: 26rpx;
}

.filter-row {
  display: flex;
  margin-top: 20rpx;
  gap: 16rpx;
}

.filter-tag {
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  background-color: #fff;
  border-radius: 24rpx;
  border: 1rpx solid #EEE;
  color: #666;
}

.filter-tag.active {
  background-color: #E8F5E9;
  color: #07C160;
  border-color: #07C160;
}

.data-card {
  background-color: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #EEE;
  position: relative;
}

.online-indicator {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #DDD;
  border: 4rpx solid #fff;
  box-shadow: 0 0 8rpx rgba(0,0,0,0.1);
}

.online-indicator.online {
  background-color: #07C160;
  box-shadow: 0 0 12rpx rgba(7, 193, 96, 0.4);
}

.data-card.frozen {
  opacity: 0.6;
  background-color: #F9F9F9;
}

.user-badge.frozen {
  background-color: #ff4d4f;
  margin-left: 12rpx;
}

.user-meta {
  font-size: 20rpx;
  color: #999;
  border-top: 1rpx solid #F0F0F0;
  padding-top: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.freeze-btn {
  margin: 0;
  padding: 0 24rpx;
  height: 52rpx;
  line-height: 52rpx;
  font-size: 22rpx;
  background-color: #ff4d4f;
  color: #fff;
  border-radius: 26rpx;
}

.freeze-btn.active {
  background-color: #07C160;
}

.empty-state {
  text-align: center;
  padding: 100rpx 0;
  color: #BBB;
  font-size: 28rpx;
}
