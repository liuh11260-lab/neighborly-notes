.violations-container {
  min-height: 100vh;
  background: #F7F7F7;
  padding: 20rpx;
}

/* 统计概览 */
.stats-header {
  display: flex;
  justify-content: space-around;
  background: white;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 20rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.stat-value.risky {
  color: #FF4444;
}

.stat-value.review {
  color: #FF9500;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

/* 筛选器 */
.filter-bar {
  background: white;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.filter-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.filter-row:last-child {
  margin-bottom: 0;
}

.filter-label {
  font-size: 28rpx;
  color: #666;
  margin-right: 20rpx;
  white-space: nowrap;
}

.filter-tabs {
  display: flex;
  gap: 16rpx;
  flex: 1;
}

.tab {
  padding: 8rpx 20rpx;
  font-size: 26rpx;
  color: #666;
  background: #F5F5F5;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.tab.active {
  background: #07C160;
  color: white;
}

.date-picker {
  flex: 1;
  padding: 8rpx 20rpx;
  font-size: 26rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  color: #666;
}

.clear-btn {
  font-size: 26rpx;
  color: #07C160;
  margin-left: 20rpx;
}

/* 违规列表 */
.violations-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.violation-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
}

.violation-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.suggest-badge {
  padding: 6rpx 16rpx;
  font-size: 24rpx;
  color: white;
  border-radius: 6rpx;
}

.suggest-badge.risky {
  background: #FF4444;
}

.suggest-badge.review {
  background: #FF9500;
}

.source-tag {
  font-size: 24rpx;
  color: #666;
  background: #F5F5F5;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
  margin-left: auto;
}

.violation-content {
  background: #F9F9F9;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  position: relative;
}

.content-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  word-break: break-all;
  display: block;
  padding-right: 80rpx;
}

.copy-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  font-size: 24rpx;
  color: #07C160;
  padding: 4rpx 12rpx;
  background: white;
  border-radius: 6rpx;
}

.violation-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.user-openid {
  font-size: 24rpx;
  color: #999;
  font-family: monospace;
}

.handle-btn {
  padding: 8rpx 24rpx;
  font-size: 26rpx;
  background: #07C160;
  color: white;
  border-radius: 8rpx;
  border: none;
}

.handle-btn.handled {
  background: #F5F5F5;
  color: #666;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
  font-size: 28rpx;
}
