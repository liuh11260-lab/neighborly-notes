/* V1 Minimalist Book Page */
.container {
  min-height: 100vh;
  background-color: #fff;
  position: relative;
  display: flex;
  flex-direction: column;
}

/* Browsing Navigation Header */
.browsing-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 40rpx 0;
  height: 120rpx;
  background-color: #fff;
  z-index: 10;
}

.nav-arrow {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 50%;
}

.arrow-icon {
  font-size: 36rpx;
  font-weight: 800;
  color: #333;
  padding-bottom: 4rpx;
}

.nav-arrow.disabled {
  opacity: 0.3;
  background: #FAFAFA;
}

.nav-arrow.disabled .arrow-icon {
  color: #CCC;
}

.nav-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.nav-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #000;
  margin-bottom: 4rpx;
}

/* Main Content Area */
.book-content {
  flex: 1;
  padding: 30rpx 60rpx 40rpx;
  display: flex;
  flex-direction: column;
}

/* Place Identity */
.place-header {
  margin-bottom: 60rpx;
}

.icon-badges {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.category-icon {
  font-size: 44rpx;
  width: 80rpx;
  height: 80rpx;
  background: #F8F8F8;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.layer-badge {
  font-size: 24rpx;
  color: #666;
  background: #FFF;
  border: 1rpx solid #EEE;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-weight: 600;
  text-transform: uppercase;
}

.place-name {
  display: block;
  font-size: 52rpx;
  font-weight: 800;
  color: #000;
  line-height: 1.2;
  margin-bottom: 30rpx;
}

/* Compact Info Row */
.place-info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 24rpx;
  border-top: 1rpx solid #F9F9F9;
}

.info-text-group {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
  margin-right: 20rpx;
}

.place-distance {
  font-weight: 700;
  color: #333;
  font-size: 26rpx;
}

.divider {
  margin: 0 12rpx;
  color: #DDD;
  font-size: 24rpx;
}

.place-address {
  font-size: 26rpx;
  color: #888;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mini-map-btn {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  background: #FFF;
  border: 2rpx solid #333; /* Visible Border */
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #333;
  display: flex;
  align-items: center;
}

/* Placeholder Vibe Area */
.book-placeholder {
  flex: 1;
  background: #FAFAFA;
  border: 3rpx dashed #E0E0E0;
  border-radius: 32rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-bottom: 300rpx; /* Increased to avoid overlap with taller footer */
  min-height: 400rpx;
  position: relative;
  padding: 40rpx;
  text-align: center;
}

.placeholder-text {
  font-size: 36rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
  color: #333;
  line-height: 1.4;
}

.placeholder-sub {
  font-size: 26rpx;
  color: #888;
  line-height: 1.5;
  max-width: 80%;
}

/* Fixed Action Bar */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 30rpx 40rpx calc(30rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -8rpx 40rpx rgba(0,0,0,0.08); 
  border-top: none;
  z-index: 100;
}

.action-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.action-row:last-child {
  margin-bottom: 0;
}

/* Judgment Buttons */
.btn-judgment {
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 800;
  flex: 1;
  border: none;
  padding: 0;
  transition: all 0.2s ease;
}

.btn-judgment.positive {
  background: #F2F2F2;
  color: #333;
  flex: 1; 
  box-shadow: none;
}

.btn-judgment.positive.checked {
  background: #07C160; 
  color: #fff;
  box-shadow: 0 8rpx 20rpx rgba(7,193,96,0.3);
}

.btn-judgment.negative {
  background: #F2F2F2;
  color: #999;
  flex: 1;
}

.btn-judgment.negative.checked {
  background: #666;
  color: #fff;
}

.btn-judgment.neutral {
  background: #FFF;
  color: #333;
  border: 4rpx solid #F0F0F0; /* Thicker border */
  font-size: 30rpx;
  height: 100rpx; 
  flex: 1; 
}
