/* Page Container */
.container {
  height: 100vh;
  background-color: #F8F8F8;
  display: flex;
  flex-direction: column;
}

.loading-container {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 100%;
  color: #999;
}

/* Header */
.header {
  padding: 120rpx 40rpx 40rpx; /* Top padding for StatusBar */
  background-color: #fff;
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.meta {
  font-size: 24rpx;
  color: #999;
  background: #F0F0F0;
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

/* Shelf List */
.shelf-scroll {
  flex: 1;
  padding-top: 20rpx;
}

/* Shelf Content Grouping */
.shelf-content {
  padding: 0 40rpx 80rpx;
  display: flex;
  flex-direction: column;
}

.shelf-section {
  margin-bottom: 50rpx;
}

.section-header {
  font-size: 32rpx;
  font-weight: 800;
  color: #333;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rotate-btn {
  font-size: 24rpx;
  color: #007AFF;
  background: #E5F1FF;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-weight: 600;
  transition: opacity 0.2s;
}

.rotate-btn:active {
  opacity: 0.7;
}

/* Horizontal Scroll */
.books-row {
  width: 100%;
  white-space: nowrap;
  height: 320rpx; /* Constrain height for layout stability */
}

/* Flex Container inside ScrollView */
.books-container {
  display: inline-flex;
  gap: 24rpx;
  padding-right: 40rpx; /* Padding for last item */
}

/* Mini Book Card */
.book-card-mini {
  width: 240rpx;
  height: 300rpx;
  border-radius: 20rpx;
  padding: 24rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.04);
  transition: all 0.1s;
}

.book-card-mini:active {
  transform: scale(0.96);
}

.book-card-mini .book-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  white-space: normal; /* Allow multiline */
  display: -webkit-box;
  -webkit-line-clamp: 4;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.book-card-mini .book-sub {
  font-size: 20rpx;
  color: rgba(0,0,0,0.4);
  margin-top: 10rpx;
}

/* Recommended Decoration */
.book-card-mini.is-recommended {
  border-width: 4rpx;
  position: relative;
}

.layer-Food.is-recommended {
  border-color: #F57F17;
}

.layer-Leisure.is-recommended {
  border-color: #01579B;
}

.recommend-badge {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: #07C160;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 10rpx rgba(7,193,96,0.3);
  z-index: 5;
}

/* Category Theming */
.layer-Food.book-card-mini {
  background-color: #FFFDE7; /* Yellow-50 */
  border: 1rpx solid #FFF59D; /* Yellow-200 */
}
.layer-Food.book-card-mini .book-title {
  color: #F57F17; /* Yellow-900 like */
}

.layer-Leisure.book-card-mini {
  background-color: #E1F5FE; /* LightBlue-50 */
  border: 1rpx solid #81D4FA; /* LightBlue-200 */
}
.layer-Leisure.book-card-mini .book-title {
  color: #01579B; /* LightBlue-900 */
}

/* Add Card (Footer Style) */
.add-card {
  height: 120rpx;
  border-radius: 24rpx;
  border: 2rpx dashed #E0E0E0;
  background: #FAFAFA;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  color: #999;
  margin-top: 20rpx;
}

/* Modal */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: flex-end; /* Bottom sheet by default or center */
  justify-content: center;
  z-index: 100;
  padding-bottom: env(safe-area-inset-bottom);
}

.modal-content {
  width: 100%;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  padding: 40rpx 40rpx 80rpx; /* Increased bottom padding */
  box-sizing: border-box; /* Ensure padding doesn't overflow width */
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.modal-header {
  margin-bottom: 30rpx;
  text-align: center;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

/* Selector */
.layer-selector {
  display: flex;
  white-space: nowrap;
  margin-bottom: 40rpx;
  max-width: 100%;
  height: 100rpx;
}

.layer-item {
  display: inline-flex;
  padding: 16rpx 32rpx;
  background: #F5F5F5;
  border-radius: 40rpx;
  margin-right: 20rpx;
  color: #666;
  font-size: 26rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
  height: 70rpx;
  align-items: center;
}

.layer-item.selected {
  background: #fff;
  border-color: #333;
  color: #333;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

/* Layer Colors in Modal */
.layer-item.selected.layer-Solitude { border-color: #66BB6A; color: #2E7D32; background: #E8F5E9; }
.layer-item.selected.layer-Couple { border-color: #EC407A; color: #C2185B; background: #FCE4EC; }
.layer-item.selected.layer-Social { border-color: #FFA726; color: #EF6C00; background: #FFF3E0; }
.layer-item.selected.layer-Work { border-color: #78909C; color: #37474F; background: #ECEFF1; }

.input-section {
  background: #F9F9F9;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
  position: relative;
}

.book-input {
  font-size: 30rpx;
  color: #333;
  width: 100%;
}

.char-count {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  font-size: 20rpx;
  color: #ccc;
}

.modal-actions {
  display: flex;
  gap: 30rpx;
}

.btn {
  flex: 1;
  height: 90rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 45rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn.cancel {
  background: #F0F0F0;
  color: #999;
}

.btn.confirm {
  background: #333;
  color: #fff;
}

.btn.confirm.disabled {
  opacity: 0.5;
}
